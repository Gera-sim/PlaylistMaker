<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorPrimaryVariant"
    android:orientation="vertical"

    tools:context=".MainActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="32dp"
        android:fontFamily="@font/ys_display_medium"
        android:text="@string/playlist_maker"
        android:textColor="?attr/colorPrimary"
        android:textSize="@dimen/main_page_text_size" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="@dimen/margin_horizontal"
        android:layout_marginEnd="@dimen/margin_horizontal"
        android:layout_marginBottom="20dp"
        android:orientation="vertical">

        <Button
            android:id="@+id/main_search"
            style="@style/MainButtonStyle"
            android:text="@string/search_ru"
            app:icon="@drawable/search" />

        <Button
            android:id="@+id/Main_Media"
            style="@style/MainButtonStyle"
            android:text="@string/media_Library_ru"
            app:icon="@drawable/music" />

        <Button
            android:id="@+id/Main_Settings"
            style="@style/MainButtonStyle"
            android:text="@string/settings_ru"
            app:icon="@drawable/settings" />

    </LinearLayout>
</LinearLayout>